# Neon (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@EP-XXXX-XXXX.eu-central-1.aws.neon.tech/neondb?sslmode=require

# API
API_HOST=0.0.0.0
API_PORT=4000

# Stripe (API — claves de TEST; ver docs/stripe-test-setup.md)
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Obtener con: stripe listen --forward-to localhost:4000/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Storefront
NEXT_PUBLIC_API_URL=http://localhost:4000
# Opcional; la API también devuelve publishableKey en payment-intent
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
